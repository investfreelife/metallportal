# =============================================================================
# Metallportal — local environment template
# Скопируй в `.env.local` и подставь реальные значения. `.env.local` в gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Site / SEO
# -----------------------------------------------------------------------------

# Canonical site URL — single source of truth для metadataBase, sitemap, robots.
# Production: https://www.harlansteel.ru
NEXT_PUBLIC_SITE_URL=https://www.harlansteel.ru

# Yandex.Metrika counter ID (число, например 87654321).
# Если пусто — счётчик не вставится в DOM (см. components/analytics/YandexMetrika.tsx).
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Yandex.Webmaster verification — content из <meta name="yandex-verification" content="...">.
# Только строка-токен, без HTML-обвязки. Если пусто — meta-тег не рендерится.
NEXT_PUBLIC_YANDEX_VERIFICATION=

# Google Search Console verification — content из <meta name="google-site-verification" content="...">.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
