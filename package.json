    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "lucide-react": "^1.8.0",
    "next": "^14.2.35",
    "next-themes": "^0.4.6",
    "openai": "^6.34.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.4.1"
