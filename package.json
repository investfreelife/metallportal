{
  "name": "metallportal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "verify-nav": "tsx scripts/verify-nav.ts",
    "build": "npm run verify-nav && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "npx supabase db push",
